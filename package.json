{
  "name": "lattice-protocol-mvp",
  "version": "0.1.0",
  "description": "Lattice Protocol MVP implementation",
  "main": "dist/index.js",
  "scripts": {
    "test": "vitest run",
    "build": "tsc",
    "lattice": "ts-node cli/lattice.ts",
    "services:echo": "ts-node services/echo/index.ts",
    "services:github": "ts-node services/github-proxy/index.ts",
    "services:gmail": "ts-node services/gmail-proxy/index.ts",
    "services:browser": "ts-node services/browser-proxy/index.ts",
    "demo": "ts-node examples/testnet-demo.ts",
    "example:gov": "ts-node examples/01-government-citizen-certificate/scenario.ts",
    "example:bank": "ts-node examples/02-bank-government-validated-transfer/scenario.ts",
    "example:manifest": "ts-node examples/03-transparency-signed-manifest/scenario.ts",
    "build:contracts": "solcjs --bin --abi --include-path contracts --base-path . -o contracts contracts/LatticeChain.sol"
  },
  "type": "commonjs",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "dependencies": {
    "@types/chalk": "^0.4.31",
    "@types/http-proxy": "^1.17.17",
    "@types/js-yaml": "^4.0.9",
    "@types/ws": "^8.18.1",
    "chalk": "^4.1.2",
    "commander": "^12.0.0",
    "ethers": "^6.16.0",
    "http-proxy": "^1.18.1",
    "js-yaml": "^4.1.0",
    "solc": "^0.8.35",
    "ws": "^8.20.0",
    "zod": "^3.22.0"
  }
}
