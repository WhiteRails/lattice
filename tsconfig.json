{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "outDir": "./dist",
    "rootDir": "./",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["core/**/*", "cli/**/*", "node/**/*", "services/**/*"],
  "exclude": ["node_modules", "**/*.test.ts"]
}
